    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>//Script here
var regiao = "Nordeste";
var microrregiao = "11ª GRE";


var cidade_tratada = upper(trim(cidade));
var escola_nome_tratada = upper(trim(escola_nome));
var bairro_tratado = upper(trim(bairro));


if (bairro_tratado == null || bairro_tratado == "") {
    var bairro_final = "NÃO INFORMADO";
} else {
    var bairro_final = bairro_tratado;
}
