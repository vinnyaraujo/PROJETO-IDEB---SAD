      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>var zona = zona;
var bairro = bairro;

if (zona == null || String(zona).trim() == "") {
    zona = "NÃO DISPONÍVEL";
}

if (bairro == null || String(bairro).trim() == "") {
    bairro = "NÃO DISPONÍVEL";
}</jsScript_script>
