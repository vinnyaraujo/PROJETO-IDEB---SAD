        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>var etapas = [];

if (IN_FUND_AI == "1") {
  etapas.push("Fundamental - Anos Iniciais");
}
if (IN_FUND_AF == "1") {
  etapas.push("Fundamental - Anos Finais");
}

if (IN_MED == "1") {
	etapas.push("Ensino Médio");
}

etapas_lista = etapas;</jsScript_script>
